# .env.example — AI Employee Environment Variables
# ====================================================
# IMPORTANT: Copy this file to .env and fill in your values.
#            NEVER commit .env to version control.
#            .env is already in .gitignore.
# ====================================================

# ---------------------------------------------------------------------------
# GENERAL
# ---------------------------------------------------------------------------

# Absolute path to this vault (used by orchestrator and scheduled tasks)
VAULT_PATH=C:/Users/YourName/AI_Employee_Vault

# Set to "false" to enable real external actions (email, LinkedIn posting)
# Keep "true" during development and testing
DRY_RUN=true


# ---------------------------------------------------------------------------
# GMAIL — IMAP (for gmail_watcher.py to READ emails)
# ---------------------------------------------------------------------------

# Your Gmail address
GMAIL_IMAP_USER=your.email@gmail.com

# Gmail App Password — NOT your account password
# Generate at: https://myaccount.google.com/apppasswords
# Steps: Google Account → Security → 2-Step Verification → App Passwords
# Select "Mail" and your device → Copy the 16-character password
GMAIL_IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# IMAP server (don't change for Gmail)
GMAIL_IMAP_HOST=imap.gmail.com

# How often to check Gmail, in seconds (default: 120 = every 2 minutes)
GMAIL_CHECK_INTERVAL=120


# ---------------------------------------------------------------------------
# GMAIL — SMTP (for email-mcp/server.py and orchestrator.py to SEND emails)
# ---------------------------------------------------------------------------

# Same Gmail address as above
GMAIL_SMTP_USER=your.email@gmail.com

# Same App Password as above (or generate a separate one)
GMAIL_SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Display name for outgoing emails
GMAIL_FROM_NAME=AI Employee

# SMTP server settings (don't change for Gmail)
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587


# ---------------------------------------------------------------------------
# LINKEDIN (for linkedin_watcher.py and draft-linkedin-post skill)
# ---------------------------------------------------------------------------
# Setup guide:
#   1. Go to https://developer.linkedin.com/
#   2. Create an App → Products → Share on LinkedIn + Sign In with LinkedIn
#   3. Request OAuth 2.0 scopes: w_member_social, r_liteprofile, r_emailaddress
#   4. Complete OAuth2 Authorization Code Flow to get access token
#   5. Tokens expire after 60 days — refresh using scripts/refresh_linkedin_token.py

# OAuth2 Access Token (expires after ~60 days)
LINKEDIN_ACCESS_TOKEN=AQX...your_access_token_here

# Your LinkedIn Person URN — find in API response or profile URL
# Format: urn:li:person:XXXXXXXXXXX
LINKEDIN_PERSON_URN=urn:li:person:your_person_id_here

# Optional: Company/Organization page URN (for company posts)
# Format: urn:li:organization:XXXXXXXXX
# Leave blank to post as personal profile
LINKEDIN_ORG_URN=

# How often to check LinkedIn for notifications (default: 300 = 5 minutes)
LINKEDIN_CHECK_INTERVAL=300


# ---------------------------------------------------------------------------
# MCP SERVER — Email (for .claude/settings.json mcpServers config)
# ---------------------------------------------------------------------------
# These are the same SMTP credentials above, referenced in MCP server config.
# No additional variables needed here — the MCP server reads GMAIL_SMTP_* above.


# ---------------------------------------------------------------------------
# SECURITY NOTES
# ---------------------------------------------------------------------------
# 1. This file (.env) must NEVER be committed to git
#    Verify: cat .gitignore | grep .env
#
# 2. Gmail App Passwords require 2-Factor Authentication to be enabled
#
# 3. LinkedIn Access Tokens expire — set a calendar reminder to refresh them
#    Run: python scripts/refresh_linkedin_token.py
#
# 4. Set DRY_RUN=false ONLY when you have verified everything works correctly
#    in dry-run mode first
#
# 5. Rotate credentials monthly per Company_Handbook.md §6
